{
  "_package": {
    "name": "finance-opc-agent-pack-fixed",
    "mode": "incremental-import",
    "version": "1.1",
    "description": "Fixed Financial Trading Multi-Agent System"
  },
  "agents": {
    "defaults": {
      "workspace": "__DOMAIN_ROOT__/workspace",
      "memorySearch": {
        "enabled": true
      },
      "subagents": {
        "maxChildrenPerAgent": 4,
        "maxSpawnDepth": 2,
        "runTimeoutSeconds": 1200
      }
    },
    "list": [
      {
        "id": "finance_main",
        "workspace": "__DOMAIN_ROOT__/workspace",
        "identity": {
          "name": "F01 Financial Commander",
          "emoji": "F01"
        },
        "tools": {
          "profile": "messaging",
          "alsoAllow": [
            "read", "write", "sessions_spawn", "subagents",
            "memory_search", "memory_get", "memory_store",
            "web_search", "web_fetch", "browser", "agents_list", "tts", "exec"
          ],
          "exec": {
            "host": "gateway",
            "security": "full",
            "ask": "off",
            "safeBins": ["pwsh", "bash", "sh", "python", "python3"],
            "strictInlineEval": true,
            "timeoutSec": 300
          }
        },
        "subagents": {
          "allowAgents": ["finance_data", "finance_analysis", "finance_trading", "finance_monitor"]
        }
      },
      {
        "id": "finance_data",
        "workspace": "__DOMAIN_ROOT__/agents/finance_data",
        "identity": {
          "name": "F02 Data Collector",
          "emoji": "F02"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read", "write", "exec", "sessions_spawn", "subagents",
            "memory_search", "memory_get", "memory_store",
            "web_search", "web_fetch", "browser", "agents_list"
          ],
          "exec": {
            "host": "gateway",
            "security": "full",
            "ask": "off",
            "safeBins": ["pwsh", "bash", "sh", "python", "python3"],
            "strictInlineEval": true,
            "timeoutSec": 180
          }
        },
        "subagents": {
          "allowAgents": []
        }
      },
      {
        "id": "finance_analysis",
        "workspace": "__DOMAIN_ROOT__/agents/finance_analysis",
        "identity": {
          "name": "F03 Market Analyst",
          "emoji": "F03"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read", "write", "exec", "sessions_spawn", "subagents",
            "memory_search", "memory_get", "memory_store",
            "web_search", "web_fetch", "browser", "agents_list"
          ],
          "exec": {
            "host": "gateway",
            "security": "full",
            "ask": "off",
            "safeBins": ["pwsh", "bash", "sh", "python", "python3"],
            "strictInlineEval": true,
            "timeoutSec": 240
          }
        },
        "subagents": {
          "allowAgents": []
        }
      },
      {
        "id": "finance_trading",
        "workspace": "__DOMAIN_ROOT__/agents/finance_trading",
        "identity": {
          "name": "F04 Trading Executor",
          "emoji": "F04"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read", "write", "exec", "sessions_spawn", "subagents",
            "memory_search", "memory_get", "memory_store",
            "web_search", "web_fetch", "browser", "agents_list"
          ],
          "exec": {
            "host": "gateway",
            "security": "full",
            "ask": "off",
            "safeBins": ["pwsh", "bash", "sh", "python", "python3"],
            "strictInlineEval": true,
            "timeoutSec": 180
          }
        },
        "subagents": {
          "allowAgents": []
        }
      },
      {
        "id": "finance_monitor",
        "workspace": "__DOMAIN_ROOT__/agents/finance_monitor",
        "identity": {
          "name": "F05 Market Monitor",
          "emoji": "F05"
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read", "write", "exec", "sessions_spawn", "subagents",
            "memory_search", "memory_get", "memory_store",
            "web_search", "web_fetch", "browser", "agents_list"
          ],
          "exec": {
            "host": "gateway",
            "security": "full",
            "ask": "off",
            "safeBins": ["pwsh", "bash", "sh", "python", "python3"],
            "strictInlineEval": true,
            "timeoutSec": 180
          }
        },
        "subagents": {
          "allowAgents": ["finance_main"]
        }
      }
    ]
  }
}
