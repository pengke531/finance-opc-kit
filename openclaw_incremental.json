{
  "_package": {
    "name": "finance-opc-agent-pack",
    "mode": "incremental-import",
    "version": "2.0",
    "description": "Financial Trading Multi-Agent System - Safe Incremental Import",
    "compatibility": {
      "preserveUserConfig": true,
      "preserveGatewaySettings": true,
      "preserveModelSettings": true,
      "preserveExistingAgents": true
    }
  },
  "agents": {
    "defaults": {
      "workspace": "__PACKAGE_ROOT__/workspace",
      "memorySearch": {
        "enabled": true
      },
      "subagents": {
        "maxChildrenPerAgent": 4,
        "maxSpawnDepth": 2,
        "runTimeoutSeconds": 1200
      }
    },
    "list": [
      {
        "id": "finance_main",
        "workspace": "__PACKAGE_ROOT__/workspace",
        "identity": {
          "name": "F01 Financial Commander",
          "emoji": "F01",
          "role": "commander",
          "instructions": "You are the Financial Commander, responsible for coordinating all financial operations and risk management."
        },
        "tools": {
          "profile": "messaging",
          "alsoAllow": [
            "read",
            "write",
            "subagents",
            "memory_search",
            "memory_get",
            "memory_store",
            "web_search",
            "web_fetch",
            "browser"
          ]
        },
        "subagents": {
          "allowAgents": [
            "finance_data",
            "finance_analysis",
            "finance_trading",
            "finance_monitor"
          ]
        },
        "system": {
          "independent": true,
          "noUserConfigOverride": true
        }
      },
      {
        "id": "finance_data",
        "workspace": "__PACKAGE_ROOT__/agents/finance_data",
        "identity": {
          "name": "F02 Data Collector",
          "emoji": "F02",
          "role": "data_provider",
          "instructions": "You are the Data Collector, responsible for gathering financial market data."
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "write",
            "memory_search",
            "memory_get",
            "memory_store",
            "web_search",
            "web_fetch",
            "browser"
          ]
        },
        "subagents": {
          "allowAgents": []
        },
        "system": {
          "independent": true,
          "noUserConfigOverride": true
        }
      },
      {
        "id": "finance_analysis",
        "workspace": "__PACKAGE_ROOT__/agents/finance_analysis",
        "identity": {
          "name": "F03 Market Analyst",
          "emoji": "F03",
          "role": "analyst",
          "instructions": "You are the Market Analyst, responsible for technical and fundamental analysis."
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "write",
            "memory_search",
            "memory_get",
            "memory_store",
            "web_search",
            "web_fetch",
            "browser"
          ]
        },
        "subagents": {
          "allowAgents": []
        },
        "system": {
          "independent": true,
          "noUserConfigOverride": true
        }
      },
      {
        "id": "finance_trading",
        "workspace": "__PACKAGE_ROOT__/agents/finance_trading",
        "identity": {
          "name": "F04 Trading Executor",
          "emoji": "F04",
          "role": "executor",
          "instructions": "You are the Trading Executor, responsible for executing trading decisions."
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "write",
            "memory_search",
            "memory_get",
            "memory_store",
            "web_search",
            "web_fetch",
            "browser"
          ]
        },
        "subagents": {
          "allowAgents": []
        },
        "system": {
          "independent": true,
          "noUserConfigOverride": true
        }
      },
      {
        "id": "finance_monitor",
        "workspace": "__PACKAGE_ROOT__/agents/finance_monitor",
        "identity": {
          "name": "F05 Market Monitor",
          "emoji": "F05",
          "role": "monitor",
          "instructions": "You are the Market Monitor, responsible for real-time market monitoring and alerts."
        },
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "write",
            "memory_search",
            "memory_get",
            "memory_store",
            "web_search",
            "web_fetch",
            "browser"
          ]
        },
        "subagents": {
          "allowAgents": [
            "finance_main"
          ]
        },
        "system": {
          "independent": true,
          "noUserConfigOverride": true
        }
      }
    ]
  },
  "skills": {
    "load": {
      "extraDirs": [
        "__PACKAGE_ROOT__/workspace/skills"
      ]
    },
    "preserveUserSkills": true
  },
  "safety": {
    "isolation": "package",
    "noUserConfigModification": true,
    "noGatewayModification": true,
    "rollbackOnError": true
  }
}
